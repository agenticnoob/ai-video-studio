REMOTION_AWS_ACCESS_KEY_ID=""
REMOTION_AWS_SECRET_ACCESS_KEY=***

# MiniMax (minimaxi.com) provider — required to enable real generation in /api/generate.
# See docs/providers/minimax.md for details.
MINIMAX_API_KEY=""
MINIMAX_MODEL="MiniMax-M2.7-highspeed"
MINIMAX_BASE_URL="https://api.minimaxi.com/v1"

# MiniMax TTS. The TTS route reuses MINIMAX_API_KEY and defaults to
# `${MINIMAX_BASE_URL}/t2a_v2`; override the endpoint if your MiniMax account
# uses a different speech URL or requires a GroupId query.
MINIMAX_GROUP_ID=""
MINIMAX_TTS_ENDPOINT=""
MINIMAX_TTS_MODEL="speech-2.8-turbo"
MINIMAX_TTS_VOICE_ID="male-qn-qingse"
MINIMAX_TTS_EMOTION=""
MINIMAX_TTS_SAMPLE_RATE="32000"
MINIMAX_TTS_BITRATE="128000"
MINIMAX_TTS_CHANNEL="1"

# TTS provider selection. Leave unset to use MiniMax unless F5_TTS_BASE_URL is
# configured. Set to "f5-tts" to force the local F5-TTS adapter path.
TTS_PROVIDER=""

# Optional local/container F5-TTS runtime. See
# docs/providers/f5-tts-service-plan.md for the planned service shape.
F5_TTS_BASE_URL=""
F5_TTS_ENDPOINT=""
F5_TTS_VOICE_ID="default"
F5_TTS_FORMAT="wav"
F5_TTS_REFERENCE_AUDIO=""
F5_TTS_FALLBACK_TO_MINIMAX="true"

# Origin used by /api/render when Remotion needs to download route media such
# as /api/tts/assets/... during local export.
AI_VIDEO_STUDIO_RENDER_ASSET_ORIGIN="http://127.0.0.1:3000"
