# Unified local configuration template.
# Copy this file to `.env`; Docker Compose and the Next app both use `.env`.
# `.env.local` is still tolerated by Next.js, but new local setup should not
# need a separate Docker env file or app env file.

HOST_UID=1000
HOST_GID=1000
APP_PORT=3000
STUDIO_PORT=3001
F5_TTS_PORT=7865

REMOTION_AWS_ACCESS_KEY_ID=""
REMOTION_AWS_SECRET_ACCESS_KEY=***

# MiniMax 文本生成配置。/api/generate 走 MiniMax 真实生成时必须配置
# MINIMAX_API_KEY。更多细节见 docs/providers/minimax.md。
# MINIMAX_API_KEY：MiniMax Bearer token；为空时真实生成会直接报配置错误。
MINIMAX_API_KEY=""
# MINIMAX_MODEL：文本/规划/编译使用的 MiniMax 模型；只通过环境变量切换。
MINIMAX_MODEL="MiniMax-M2.7-highspeed"
# MINIMAX_BASE_URL：MiniMax API base URL；一般不用改，除非走自建网关。
MINIMAX_BASE_URL="https://api.minimaxi.com/v1"

# MiniMax TTS 配置。/api/tts 复用 MINIMAX_API_KEY；默认请求
# `${MINIMAX_BASE_URL}/t2a_v2`。
# MINIMAX_GROUP_ID：部分 MiniMax 账号需要的 GroupId query 参数。
MINIMAX_GROUP_ID=""
# MINIMAX_TTS_ENDPOINT：完整 TTS endpoint 覆盖；为空时用默认 t2a_v2。
MINIMAX_TTS_ENDPOINT=""
# MINIMAX_TTS_MODEL：MiniMax 语音模型。
MINIMAX_TTS_MODEL="speech-2.8-turbo"
# MINIMAX_TTS_VOICE_ID：MiniMax 默认音色 id。
MINIMAX_TTS_VOICE_ID="male-qn-qingse"
# MINIMAX_TTS_EMOTION：可选情绪参数；为空则不发送。
MINIMAX_TTS_EMOTION=""
# MINIMAX_TTS_SAMPLE_RATE：请求的采样率，必须是正整数。
MINIMAX_TTS_SAMPLE_RATE="32000"
# MINIMAX_TTS_BITRATE：请求的音频码率，必须是正整数。
MINIMAX_TTS_BITRATE="128000"
# MINIMAX_TTS_CHANNEL：请求声道数，只能是 1 或 2。
MINIMAX_TTS_CHANNEL="1"

# TTS provider 选择。可填 "f5-tts" 或 "minimax"。
# 为空时：如果配置了 F5_TTS_BASE_URL 就自动用 f5-tts，否则用 minimax。
TTS_PROVIDER=""

# 可选本地/容器 F5-TTS runtime。真实用户生成请用 scripts/f5-tts-real.sh
# 启动 GPU overlay；普通 docker-compose.f5.yml 默认是 contract-smoke，只用于
# HTTP 合同验证，不代表真实 F5 音频时长。
# F5_TTS_BASE_URL：Next app 访问 F5 服务的 base URL；Docker 内一般是
# http://f5-tts:7865，宿主机 smoke 一般是 http://127.0.0.1:7865。
F5_TTS_BASE_URL=""
# F5_TTS_ENDPOINT：F5 合成接口；为空时默认 `${F5_TTS_BASE_URL}/synthesize`。
F5_TTS_ENDPOINT=""
# F5_TTS_VOICE_ID：传给 F5 adapter 的默认声音 id；当前主要用于统一字段。
F5_TTS_VOICE_ID="default"
# F5_TTS_FORMAT：Next 侧保存到 out/tts 的音频格式，F5 推荐 wav。
F5_TTS_FORMAT="wav"
# F5_TTS_REFERENCE_AUDIO：请求级参考音频路径，必须是 F5 容器能访问的路径。
F5_TTS_REFERENCE_AUDIO=""
# F5_TTS_FALLBACK_TO_MINIMAX：F5 请求失败时是否自动退回 MiniMax TTS。
F5_TTS_FALLBACK_TO_MINIMAX="true"
# F5_TTS_SERVICE_MODE：F5 runtime 模式。f5 会加载本地 checkpoint 做真实合成；
# contract-smoke 只返回测试音频，听起来会像持续“嘟”声。
F5_TTS_SERVICE_MODE="f5"
# F5_TTS_PORT：F5 HTTP 服务暴露到宿主机的端口，已在文件顶部定义。
# F5_TTS_MODEL_PATH：F5 checkpoint 在容器内的路径。
F5_TTS_MODEL_PATH="/models/f5-tts/model_1250000.safetensors"
# F5_TTS_VOCAB_PATH：F5 vocab 文件在容器内的路径。
F5_TTS_VOCAB_PATH="/models/f5-tts/vocab.txt"
# F5_TTS_VOCODER_PATH：Vocos vocoder 在容器内的路径。
F5_TTS_VOCODER_PATH="/models/f5-tts/vocos-mel-24khz"
# F5_TTS_ALLOW_VOCODER_DOWNLOAD：vocoder 缺失时是否允许运行时下载；本机建议 false。
F5_TTS_ALLOW_VOCODER_DOWNLOAD="false"
# F5_TTS_DEVICE：F5 运行设备；GPU overlay 默认 cuda，CPU 仅建议诊断使用。
F5_TTS_DEVICE=""
# F5_TTS_NFE_STEP：F5 推理步数；越高可能更稳但更慢，默认 16。
F5_TTS_NFE_STEP="16"
# F5_TTS_DEFAULT_REFERENCE_AUDIO：runtime 默认参考音频；请求未传 referenceAudio 时使用。
F5_TTS_DEFAULT_REFERENCE_AUDIO=""
# F5_TTS_DEFAULT_REFERENCE_TEXT：默认参考音频对应文本；自定义音色时必须和音频内容匹配。
F5_TTS_DEFAULT_REFERENCE_TEXT=""

# /api/render 本地导出时，Remotion 下载 /api/tts/assets/... 等 route media
# 使用的 Next app origin。
AI_VIDEO_STUDIO_RENDER_ASSET_ORIGIN="http://127.0.0.1:3000"
